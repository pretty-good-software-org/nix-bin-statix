#!/usr/bin/env bash
#MISE description="Create GitHub Release with artifacts"
set -euo pipefail

TOOL_NAME="${TOOL_NAME:?TOOL_NAME is required}"
VERSION="${VERSION:?VERSION is required}"
GH_TOKEN="${GH_TOKEN:?GH_TOKEN is required}"

gh release create "v${VERSION}" \
  --title "${TOOL_NAME} v${VERSION}" \
  --notes "Prebuilt binaries for ${TOOL_NAME} v${VERSION} from upstream." \
  artifacts/*
