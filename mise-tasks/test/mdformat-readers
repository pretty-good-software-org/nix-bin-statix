#!/usr/bin/env bash
#MISE description="Test concurrent formatter readers during environment publication"
set -euo pipefail

readonly test_root="$(mktemp -d "${TMPDIR:-/tmp}/mdformat-readers.XXXXXX")"
cleanup() {
  local status=$?
  rm -rf "$test_root" || printf 'mdformat reader tests: failed to remove test directory: %s\n' "$test_root" >&2
  exit "$status"
}
trap cleanup EXIT

set +e
(
  MISE_ENV=ci XDG_CACHE_HOME="$test_root/cache" mise run lint > "$test_root/lint.out" 2>&1
) & lint_pid=$!
(
  MISE_ENV=ci XDG_CACHE_HOME="$test_root/cache" MDFORMAT_TEST_CACHE_HOME="$test_root/cache" \
    mise run test:mdformat > "$test_root/test.out" 2>&1
) & test_pid=$!
wait "$lint_pid"; lint_status=$?
wait "$test_pid"; test_status=$?
set -e

printf 'mdformat reader tests: lint=%s test=%s\n' "$lint_status" "$test_status"
((lint_status == 0 && test_status == 0)) || {
  printf '%s\n' '--- lint output ---' >&2
  cat "$test_root/lint.out" >&2
  printf '%s\n' '--- test output ---' >&2
  cat "$test_root/test.out" >&2
  exit 1
}
! grep -Hliq -- 'No such file or directory\|UNLOCKED-MDFORMAT\|Traceback' \
  "$test_root/lint.out" "$test_root/test.out" || {
  printf 'mdformat reader tests: concurrent reader observed an invalid publication\n' >&2
  grep -Hlin -- 'No such file or directory\|UNLOCKED-MDFORMAT\|Traceback' \
    "$test_root/lint.out" "$test_root/test.out" >&2
  exit 1
}

printf 'mdformat concurrent reader tests passed\n'
