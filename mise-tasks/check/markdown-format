#!/usr/bin/env bash
#MISE description="Check tracked Markdown formatting with rumdl"
set -euo pipefail

readonly project_root="${MISE_PROJECT_ROOT:?MISE_PROJECT_ROOT must be set by mise}"

cd "$project_root"
git ls-files -z -- '*.md' | xargs -0 rumdl fmt --check --extend-enable MD029,MD060 --config 'MD060.enabled = true' --
