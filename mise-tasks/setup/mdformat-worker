#!/bin/bash
# Run the hash-locked installation inside the supervisor-created process group.
set -euo pipefail

readonly uv_bin="$1"
readonly temporary_environment_dir="$2"
readonly python_bin="$3"
readonly requirements_lock="$4"

"$uv_bin" venv \
  --allow-existing \
  --relocatable \
  --python "$python_bin" \
  "$temporary_environment_dir" || {
  printf 'mdformat setup: failed to create temporary Python environment\n' >&2
  exit 1
}

"$uv_bin" pip sync \
  --require-hashes \
  --python "$temporary_environment_dir/bin/python" \
  "$requirements_lock" || {
  printf 'mdformat setup: hash-locked requirements installation failed\n' >&2
  exit 1
}
